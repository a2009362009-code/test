{
  "openapi": "3.0.3",
  "info": {
    "title": "Barbershop Booking API",
    "version": "1.1.0",
    "description": "Backend API for barbershop booking."
  },
  "servers": [
    {
      "url": "https://test-4p5l.onrender.com"
    },
    {
      "url": "http://localhost:4000"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          }
        }
      },
      "ReadyResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ready"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "ValidationErrorResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorResponse"
          },
          {
            "type": "object",
            "properties": {
              "details": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        ]
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "fullName",
          "email",
          "phone",
          "password"
        ],
        "properties": {
          "fullName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 6
          }
        }
      },
      "UserPublic": {
        "type": "object",
        "required": [
          "id",
          "fullName",
          "email",
          "phone"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "fullName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "UserPublicSnake": {
        "type": "object",
        "required": [
          "id",
          "full_name",
          "email",
          "phone",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "full_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "required": [
          "user"
        ],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserPublicSnake"
          }
        }
      },
      "UserLoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "UserLoginResponse": {
        "type": "object",
        "required": [
          "token",
          "user"
        ],
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserPublic"
          }
        }
      },
      "AdminLoginRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "AdminLoginResponse": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "Barber": {
        "type": "object",
        "required": [
          "id",
          "name",
          "role",
          "experience_years",
          "rating",
          "reviews_count",
          "is_available",
          "specialties",
          "salon_id",
          "salon",
          "is_active",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "experience_years": {
            "type": "integer"
          },
          "rating": {
            "type": "number"
          },
          "reviews_count": {
            "type": "integer"
          },
          "image_url": {
            "type": "string",
            "nullable": true
          },
          "is_available": {
            "type": "boolean"
          },
          "specialties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "salon_id": {
            "type": "integer"
          },
          "salon": {
            "$ref": "#/components/schemas/Salon"
          },
          "bio": {
            "type": "string",
            "nullable": true
          },
          "is_active": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Service": {
        "type": "object",
        "required": [
          "id",
          "name",
          "duration_minutes",
          "price"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "duration_minutes": {
            "type": "integer"
          },
          "price": {
            "type": "string",
            "example": "500.00"
          }
        }
      },
      "Product": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "price",
          "category",
          "type",
          "stock_qty"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "string",
            "example": "650.00"
          },
          "image_url": {
            "type": "string",
            "nullable": true
          },
          "category": {
            "type": "string",
            "enum": [
              "men",
              "women",
              "unisex"
            ]
          },
          "type": {
            "type": "string"
          },
          "stock_qty": {
            "type": "integer"
          }
        }
      },
      "Slot": {
        "type": "object",
        "required": [
          "id",
          "barber_id",
          "date",
          "time"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "barber_id": {
            "type": "integer"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "time": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "available",
              "booked",
              "blocked"
            ]
          }
        }
      },
      "BookingRequest": {
        "type": "object",
        "required": [
          "serviceId",
          "barberId",
          "date",
          "time"
        ],
        "properties": {
          "serviceId": {
            "type": "integer"
          },
          "barberId": {
            "type": "integer"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "time": {
            "type": "string",
            "example": "10:30"
          }
        }
      },
      "BookingCreatedResponse": {
        "type": "object",
        "required": [
          "id",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AdminBooking": {
        "type": "object",
        "required": [
          "id",
          "client_name",
          "client_phone",
          "date",
          "time",
          "service_name",
          "barber_name"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "client_name": {
            "type": "string"
          },
          "client_phone": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "time": {
            "type": "string"
          },
          "service_name": {
            "type": "string"
          },
          "barber_name": {
            "type": "string"
          }
        }
      },
      "AdminUsersResponse": {
        "type": "object",
        "required": [
          "items",
          "limit",
          "offset"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "full_name",
                "email",
                "phone",
                "created_at"
              ],
              "properties": {
                "id": {
                  "type": "integer"
                },
                "full_name": {
                  "type": "string"
                },
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "phone": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      },
      "SlotCreateRequest": {
        "type": "object",
        "required": [
          "barberId",
          "date",
          "times"
        ],
        "properties": {
          "barberId": {
            "type": "integer"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "times": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "10:00"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "available",
              "blocked"
            ]
          }
        }
      },
      "SlotCreateResponse": {
        "type": "object",
        "required": [
          "created",
          "skipped"
        ],
        "properties": {
          "created": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "time",
                "status"
              ],
              "properties": {
                "id": {
                  "type": "integer"
                },
                "time": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "available",
                    "booked",
                    "blocked"
                  ]
                }
              }
            }
          },
          "skipped": {
            "type": "integer"
          }
        }
      },
      "Review": {
        "type": "object",
        "required": [
          "id",
          "barber_id",
          "author_name",
          "rating",
          "comment",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "barber_id": {
            "type": "integer"
          },
          "author_name": {
            "type": "string"
          },
          "rating": {
            "type": "number"
          },
          "comment": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ReviewCreateRequest": {
        "type": "object",
        "required": [
          "rating",
          "comment"
        ],
        "properties": {
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "comment": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000
          }
        }
      },
      "ReviewCreateResponse": {
        "type": "object",
        "required": [
          "review",
          "barber"
        ],
        "properties": {
          "review": {
            "$ref": "#/components/schemas/Review"
          },
          "barber": {
            "type": "object",
            "required": [
              "id",
              "rating",
              "reviews_count"
            ],
            "properties": {
              "id": {
                "type": "integer"
              },
              "rating": {
                "type": "number"
              },
              "reviews_count": {
                "type": "integer"
              }
            }
          }
        }
      },
      "MyBooking": {
        "type": "object",
        "required": [
          "id",
          "service_id",
          "service_name",
          "service_price",
          "barber_id",
          "barber_name",
          "salon_id",
          "salon_name",
          "salon_address",
          "date",
          "time",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "service_id": {
            "type": "integer"
          },
          "service_name": {
            "type": "string"
          },
          "service_price": {
            "type": "string",
            "example": "500.00"
          },
          "barber_id": {
            "type": "integer"
          },
          "barber_name": {
            "type": "string"
          },
          "salon_id": {
            "type": "integer"
          },
          "salon_name": {
            "type": "string"
          },
          "salon_address": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "time": {
            "type": "string",
            "example": "10:30:00"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BookingCancelResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "cancelled"
          }
        }
      },
      "UserProfileUpdateRequest": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "fullName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "UserProfileUpdateResponse": {
        "type": "object",
        "required": [
          "user"
        ],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserPublicSnake"
          }
        }
      },
      "Salon": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "work_hours": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "is_active": {
            "type": "boolean"
          },
          "sort_order": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "code",
          "name",
          "address",
          "work_hours",
          "latitude",
          "longitude",
          "is_active",
          "sort_order",
          "created_at",
          "updated_at"
        ]
      },
      "UserPasswordUpdateRequest": {
        "type": "object",
        "required": [
          "currentPassword",
          "newPassword"
        ],
        "properties": {
          "currentPassword": {
            "type": "string",
            "minLength": 1
          },
          "newPassword": {
            "type": "string",
            "minLength": 6
          }
        }
      },
      "UserPasswordUpdateResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "password_updated"
            ]
          }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Liveness probe",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Process is alive",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/ready": {
      "get": {
        "summary": "Readiness probe",
        "operationId": "getReady",
        "responses": {
          "200": {
            "description": "Dependencies are ready",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyResponse"
                }
              }
            }
          },
          "503": {
            "description": "Database unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/barbers": {
      "get": {
        "summary": "List active barbers",
        "operationId": "getBarbers",
        "parameters": [
          {
            "in": "query",
            "name": "salonId",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Filter barbers by salon id"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Barber"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/services": {
      "get": {
        "summary": "List active services",
        "operationId": "getServices",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Service"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "summary": "List active shop products",
        "operationId": "getProducts",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "men",
                "women",
                "unisex"
              ]
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/slots": {
      "get": {
        "summary": "List slots",
        "operationId": "getSlots",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "barberId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "available",
                "booked",
                "blocked"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Slot"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register user",
        "operationId": "registerUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "User already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "operationId": "loginUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserLoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many login attempts",
            "content": {
              "application/json": {
                "schema": {
