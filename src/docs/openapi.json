{
  "openapi": "3.0.3",
  "info": {
    "title": "Barbershop Booking API",
    "version": "1.0.0",
    "description": "Backend API for barbershop booking."
  },
  "servers": [
    {
      "url": "https://test-4p5l.onrender.com"
    },
    {
      "url": "http://localhost:4000"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["fullName", "email", "phone", "password"],
        "properties": {
          "fullName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "password": { "type": "string", "minLength": 6 }
        }
      },
      "UserLoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "AdminLoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "BookingRequest": {
        "type": "object",
        "required": ["serviceId", "barberId", "date", "time"],
        "properties": {
          "serviceId": { "type": "integer" },
          "barberId": { "type": "integer" },
          "date": { "type": "string", "example": "2026-03-20" },
          "time": { "type": "string", "example": "10:30" }
        }
      },
      "SlotCreateRequest": {
        "type": "object",
        "required": ["barberId", "date", "times"],
        "properties": {
          "barberId": { "type": "integer" },
          "date": { "type": "string", "example": "2026-03-20" },
          "times": {
            "type": "array",
            "items": { "type": "string", "example": "10:00" }
          },
          "status": { "type": "string", "enum": ["available", "blocked"] }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "string", "example": "650.00" },
          "image_url": { "type": "string", "nullable": true },
          "category": { "type": "string", "enum": ["men", "women", "unisex"] },
          "type": { "type": "string" },
          "stock_qty": { "type": "integer" }
        }
      },
      "Salon": {
        "type": "object",
        "required": ["id", "code", "name", "address", "work_hours"],
        "properties": {
          "id": { "type": "integer" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "address": { "type": "string" },
          "work_hours": { "type": "string" },
          "latitude": { "type": "string", "nullable": true, "example": "42.876500" },
          "longitude": { "type": "string", "nullable": true, "example": "74.588200" },
          "sort_order": { "type": "integer" },
          "is_active": { "type": "boolean" }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health check with database connectivity",
        "responses": {
          "200": { "description": "OK" },
          "503": { "description": "Database unavailable" }
        }
      }
    },
    "/api/ready": {
      "get": {
        "summary": "Readiness check with database dependency",
        "responses": {
          "200": { "description": "Ready" },
          "503": { "description": "Not ready" }
        }
      }
    },
    "/api/barbers": {
      "get": {
        "summary": "List active barbers",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/salons": {
      "get": {
        "summary": "List active salons",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Salon" }
                }
              }
            }
          }
        }
      }
    },
    "/api/services": {
      "get": {
        "summary": "List active services",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/products": {
      "get": {
        "summary": "List active shop products",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["men", "women", "unisex"] }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/slots": {
      "get": {
        "summary": "List slots",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "barberId",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["available", "booked", "blocked"] }
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Invalid query" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "409": { "description": "User already exists" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserLoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Invalid credentials" },
          "429": { "description": "Too many login attempts" }
        }
      }
    },
    "/api/bookings": {
      "post": {
        "summary": "Create booking",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BookingRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "409": { "description": "Slot not available" }
        }
      }
    },
    "/api/admin/login": {
      "post": {
        "summary": "Admin login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminLoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Invalid credentials" },
          "429": { "description": "Too many login attempts" }
        }
      }
    },
    "/api/admin/bookings": {
      "get": {
        "summary": "List bookings",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "barberId",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/admin/bookings/{id}": {
      "delete": {
        "summary": "Delete booking",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/admin/slots": {
      "get": {
        "summary": "List slots",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "barberId",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["available", "booked", "blocked"] }
          }
        ],
        "responses": {
          "200": { "description": "OK" }
        }
      },
      "post": {
        "summary": "Create slots",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SlotCreateRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/api/admin/slots/{id}": {
      "delete": {
        "summary": "Delete slot",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" },
          "409": { "description": "Slot is booked" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/admin/users": {
      "get": {
        "summary": "List users",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/admin/salons": {
      "get": {
        "summary": "List salons (admin)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "includeInactive",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": { "description": "OK" }
        }
      },
      "post": {
        "summary": "Create salon",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code", "name", "address", "workHours"],
                "properties": {
                  "code": { "type": "string", "example": "centr-bishkek" },
                  "name": { "type": "string", "example": "HairLine Center" },
                  "address": { "type": "string", "example": "пр. Чуй, 150" },
                  "workHours": { "type": "string", "example": "09:00 - 21:00" },
                  "latitude": { "type": "number", "nullable": true },
                  "longitude": { "type": "number", "nullable": true },
                  "sortOrder": { "type": "integer", "default": 100 },
                  "isActive": { "type": "boolean", "default": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "409": { "description": "Salon already exists" }
        }
      }
    },
    "/api/admin/salons/{id}": {
      "patch": {
        "summary": "Update salon",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "address": { "type": "string" },
                  "workHours": { "type": "string" },
                  "latitude": { "type": "number", "nullable": true },
                  "longitude": { "type": "number", "nullable": true },
                  "sortOrder": { "type": "integer" },
                  "isActive": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" },
          "404": { "description": "Not found" }
        }
      }
    }
  }
}
